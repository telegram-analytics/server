  "info": {
    "description": "Self-hosted, privacy-first analytics platform controlled entirely through a Telegram bot.",
    "title": "tgram-analytics",
    "version": "0.1.0"
  },
  "openapi": "3.1.0",
  "paths": {
    "/api/v1/internal/projects": {
      "get": {
        "operationId": "list_projects_endpoint_api_v1_internal_projects_get",
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "items": {
                    "$ref": "#/components/schemas/ProjectResponse"
                  },
                  "title": "Response List Projects Endpoint Api V1 Internal Projects Get",
                  "type": "array"
                }
              }
            },
            "description": "Successful Response"
          }
        },
        "security": [
          {
            "APIKeyHeader": []
          }
        ],
        "summary": "List all projects",
        "tags": [
          "internal"
        ]
      },
      "post": {
        "description": "Create a new project.\n\nThe ``api_key`` field in the response is the **only** time the\nplaintext key is shown \u2014 it is hashed before storage and cannot be\nretrieved again.",
        "operationId": "create_project_endpoint_api_v1_internal_projects_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/ProjectCreate"
              }
            }
          },
          "required": true
        },
        "responses": {
          "201": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectWithKeyResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "security": [
          {
            "APIKeyHeader": []
          }
        ],
        "summary": "Create a project and receive its API key",
        "tags": [
          "internal"
        ]
      }
    },
    "/api/v1/internal/projects/{project_id}": {
      "delete": {
        "operationId": "delete_project_endpoint_api_v1_internal_projects__project_id__delete",
        "parameters": [
          {
            "in": "path",
            "name": "project_id",
            "required": true,
            "schema": {
              "format": "uuid",
              "title": "Project Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "204": {
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "security": [
          {
            "APIKeyHeader": []
          }
        ],
        "summary": "Delete a project and all its data",
        "tags": [
          "internal"
        ]
      },
      "get": {
        "operationId": "get_project_endpoint_api_v1_internal_projects__project_id__get",
        "parameters": [
          {
            "in": "path",
            "name": "project_id",
            "required": true,
            "schema": {
              "format": "uuid",
              "title": "Project Id",
              "type": "string"
            }
          }
        ],
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ProjectResponse"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "security": [
          {
            "APIKeyHeader": []
          }
        ],
        "summary": "Get a single project by ID",
        "tags": [
          "internal"
        ]
      }
    },
    "/api/v1/pageview": {
      "post": {
        "description": "Ingest a pageview event.\n\nForces ``event_name = \"pageview\"`` and stores url/referrer in dedicated\ncolumns as well as in ``properties`` for easy querying.",
        "operationId": "pageview_api_v1_pageview_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/PageviewRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Pageview Api V1 Pageview Post",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Pageview",
        "tags": [
          "ingestion"
        ]
      }
    },
    "/api/v1/track": {
      "post": {
        "description": "Ingest a custom event.\n\nReturns 202 immediately; alert evaluation runs as a background task.",
        "operationId": "track_api_v1_track_post",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/TrackEventRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "202": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": true,
                  "title": "Response Track Api V1 Track Post",
                  "type": "object"
                }
              }
            },
            "description": "Successful Response"
          },
          "422": {
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/HTTPValidationError"
                }
              }
            },
            "description": "Validation Error"
          }
        },
        "summary": "Track",
        "tags": [
          "ingestion"
        ]
      }
    },
    "/health": {
      "get": {
        "description": "Return ``{\"status\": \"ok\"}`` when the server is running.",
        "operationId": "health_health_get",
        "responses": {
          "200": {
